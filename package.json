{
  "name": "openscanlink",
  "version": "1.0.0",
  "description": "OpenScanLink (开源网页扫描桥接器)",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx,.vue,.js,.jsx --fix",
    "typecheck:node": "tsc -p tsconfig.json --noEmit",
    "typecheck:renderer": "vue-tsc -p src/renderer/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:node",
    "start": "chcp 65001 && electron-vite preview",
    "dev": "chcp 65001 && electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.openscan.link",
    "productName": "OpenScanLink",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**/*"
    ],
    "extraResources": [
      {
        "from": "bridge",
        "to": "bridge",
        "filter": [
          "**/*",
          "!ScannerService/**/*",
          "!ScannerService",
          "!*.pdb",
          "!*.xml",
          "!test_param.json"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenScanLink",
      "runAfterFinish": true,
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "express": "^4.18.0",
    "sharp": "^0.32.6",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "electron-vite": "^2.0.0",
    "element-plus": "^2.4.0",
    "pinia": "^2.1.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "vue": "^3.3.0",
    "vue-router": "^4.2.0",
    "vue-tsc": "^1.8.0"
  }
}

{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@common/*": ["src/common/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src/main/**/*.ts", "src/preload/**/*.ts", "src/common/**/*.ts"],
  "exclude": ["node_modules", "src/renderer"]
}
